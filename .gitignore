# ══════════════════════════════════════════════
# O2S — Production .gitignore
# ══════════════════════════════════════════════

# ── Dependencies ──
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build Output ──
/.next/
/out/
/build/
/dist/
/.turbo/
/storybook-static/

# ── Environment Variables ──
.env
.env.*
!.env.example
!.env.template

# ── IDE & Editor ──
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS Files ──
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Debug & Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# ── Testing & Coverage ──
/coverage/
/.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/
junit.xml

# ── TypeScript ──
*.tsbuildinfo
next-env.d.ts

# ── Secrets & Credentials ──
*.pem
*.key
*.cert
*.p12
*.pfx
*.jks
credentials.json
service-account.json
*.keystore

# ── Deployment ──
.vercel/
.netlify/
.serverless/
.amplify/
cdk.out/

# ── Docker ──
docker-compose.override.yml

# ── Database ──
*.sqlite
*.sqlite3
*.db
/prisma/migrations/**/migration_lock.toml

# ── Temporary Files ──
/tmp/
/temp/
*.tmp
*.bak
*.swp
*.cache

# ── Package Lock (keep only one) ──
# Uncomment the ones you DON'T use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ── Generated Files ──
/public/sw.js
/public/workbox-*.js
/public/sitemaps/
/.contentlayer/
/.claude/

# ── Misc ──
*.map.js
.eslintcache
.stylelintcache
.prettiercache
